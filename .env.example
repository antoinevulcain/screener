# Connection to the DATA Postgres (where inpi_financial_statements_* live).
# This is the same DB hosting `inpi_financial_statements_ftp`, `_api`, `_ex`,
# and `sirene_companies`. The screener TABLE will be created here so that
# joins are local.
DATABASE_URL_DATA=postgresql://USER:PASS@host:port/railway

# Optional: lower per-query statement timeout to avoid pinning the shared
# replica during nightly batch (in milliseconds). Default: 60000.
STATEMENT_TIMEOUT_MS=60000

# Cron mode: how many minutes the cron loop sleeps between runs (default 1440 = 24h).
SCREENER_CRON_INTERVAL_MIN=1440

# Migration scope (always 'screener' for this workspace).
MIGRATE_SCOPE=screener
